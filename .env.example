# ============================================================================
# SMARTHUB CONNECT — ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to `.env.local` (for local dev) or set these in the Vercel
# dashboard (for production). NEVER commit your real .env.local to GitHub.
#
# How to use on Vercel:
#   1. Go to your project → Settings → Environment Variables
#   2. Add each variable below with its real value
#   3. Redeploy
# ============================================================================

# ---------------------------------------------------------------------------
# DATABASE (Prisma)
# ---------------------------------------------------------------------------
# SQLite file path for local dev. On Vercel, use a real database like Postgres
# (Vercel Postgres, Supabase, Neon, etc.) and update prisma/schema.prisma
# to change the datasource provider from "sqlite" to "postgresql".
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# CONTACT FORM (Formspree)
# ---------------------------------------------------------------------------
# Sign up at https://formspree.io and create a new form.
# They'll give you an endpoint like https://formspree.io/f/abcd1234
# Put that here. Without this, the contact form will show an error message.
NEXT_PUBLIC_FORMSPREE_ENDPOINT="https://formspree.io/f/your-form-id"

# ---------------------------------------------------------------------------
# ANALYTICS (optional — Plausible)
# ---------------------------------------------------------------------------
# Sign up at https://plausible.io, add your site, and put the domain here.
# Then uncomment the Plausible script in src/app/layout.tsx
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="smarthubc.com"

# ---------------------------------------------------------------------------
# NEWSLETTER (optional — Mailchimp / ConvertKit / Loops)
# ---------------------------------------------------------------------------
# When you wire up the newsletter form in src/components/pages/insights.tsx
# to a real provider, put the API endpoint here.
# NEXT_PUBLIC_NEWSLETTER_ENDPOINT="https://manage.kmail-lists.com/..."