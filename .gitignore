# ============================================================================
# SMARTHUB CONNECT — .gitignore
# ============================================================================
# Files and folders that should NOT be committed to GitHub.
# ============================================================================

# ---------- Dependencies ----------
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------- Testing ----------
/coverage

# ---------- Next.js ----------
/.next/
/out/

# ---------- Production builds ----------
/build

# ---------- Misc OS / editor ----------
.DS_Store
Thumbs.db
*.pem
*.swp
.vscode/
.idea/

# ---------- Debug logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Environment files (NEVER COMMIT SECRETS) ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# NOTE: .env.example IS committed (it has no real secrets, just placeholders)

# ---------- Vercel ----------
.vercel

# ---------- TypeScript ----------
*.tsbuildinfo
next-env.d.ts

# ---------- Project-specific junk ----------
# Dev server logs
dev.log
server.log
*.log

# Sandbox / scaffold internal folders (not part of the actual project)
/.zscripts/
/scripts/
/tool-results/
/worklog.md

# Claude / AI config
.claude
.z-ai-config
local-*
prompt

# Database files (SQLite — local dev only)
/db/*.db
/db/*.db-journal

# ---------- Documentation artifacts (optional — comment out if you want to commit) ----------
# /docs/  # uncomment to ignore docs folder
